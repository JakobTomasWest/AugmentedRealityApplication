<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext is blocked globally except for:
      • localhost  — physical device traffic forwarded via `adb reverse tcp:8080 tcp:8080`
      • 10.0.2.2   — Android emulator alias for the host machine
    Both point at the same Ktor dev server on port 8080.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>